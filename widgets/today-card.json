{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        { "type": "Column", "width": "stretch", "items": [
          { "type": "TextBlock", "text": "하루두잉 ${mood}", "weight": "bolder", "size": "medium" }
        ]},
        { "type": "Column", "width": "auto", "items": [
          { "type": "TextBlock", "text": "남은 일 ${remaining}", "color": "attention", "weight": "bolder" }
        ]}
      ]
    },
    {
      "type": "Container",
      "$data": "${items}",
      "items": [
        { "type": "TextBlock", "text": "${sym} ${text}", "wrap": false, "spacing": "small" }
      ]
    }
  ]
}
